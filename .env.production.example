# ==============================================================================
# ChatSphere V1 - Production Environment Template
# ==============================================================================
# IMPORTANT: DO NOT commit your actual .env.production file containing secrets!
# To deploy:
# 1. Copy this file to .env.production on the production host server:
#    cp .env.production.example .env.production
# 2. Populate the real secrets below.
# ==============================================================================

# Database Configuration
# Sourced by postgres and backend services in docker-compose.prod.yml
DB_USER=chatsphere_admin
DB_PASSWORD=YOUR_SECURE_GENERATED_PASSWORD_HERE
DB_NAME=chatsphere_prod

# Backend Security Configuration
# Sourced by backend service
JWT_SECRET=YOUR_SECURE_JWT_SECRET_KEY_HERE
PORT=8080

# Frontend Production Configuration
# Injected at build time during 'docker compose -f docker-compose.prod.yml build'
# Use relative paths if proxying through the same domain, or specify your public endpoints.
VITE_API_URL=https://yourdomain.com/api/v1
VITE_WS_URL=wss://yourdomain.com/ws
